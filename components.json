{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-nova",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "app/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "ui": {
    "tooltip": {
      "name": "Tooltip",
      "style": "radix-nova",
      "props": {
        "side": {
          "type": "enum",
          "default": "top",
          "options": ["top", "right", "bottom", "left"]
        },
        "sideOffset": {
          "type": "number",
          "default": 4
        }
      }
    }
  },
  "menuColor": "default",
  "menuAccent": "subtle",
  "registries": {}
}
